# Merge these routes/directives into the existing canadaverse.org site block.
# The API route must be handled before the static splashpage file server.

# The live cloudflared container uses host networking, and its origin
# connections reach Caddy from the Pi's own 192.168.0.111 address. Preserve
# this route order: LAN clients that are not the local cloudflared peer get 403.
route /api/meshcore-regions/proposals* {
    @cloudflared_peer remote_ip 192.168.0.111
    reverse_proxy @cloudflared_peer region-proposal-gateway:8787 {
        # Never pass a browser-supplied forwarding chain. Only the verified
        # cloudflared ingress may supply CF-Connecting-IP.
        header_up -X-Forwarded-For
        header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
    }
    respond "Forbidden" 403
}

# Edit the site's EXISTING global Content-Security-Policy line; do not add a
# second CSP header. Preserve every current host/directive, and add:
#   script-src:  https://challenges.cloudflare.com
#   frame-src:   https://challenges.cloudflare.com
#   connect-src: https://challenges.cloudflare.com
