# Add this site block to Caddy on the MeshCore Canada production host.
# Point regions-api.meshcore.ca at that host before reloading Caddy. Caddy will
# obtain and renew the public TLS certificate when ports 80 and 443 are open.

regions-api.meshcore.ca {
	@proposal_api {
		path /api/meshcore-regions/proposals /api/meshcore-regions/proposals/*
	}

	handle @proposal_api {
		# The container uses host networking and listens on loopback only.
		# Caddy ignores browser-supplied X-Forwarded-For by default and sends
		# the real direct client address to the proposal service.
		reverse_proxy 127.0.0.1:8787
	}

	respond "Not found" 404
}

# If the GitHub Pages editor later adds a Content-Security-Policy, it must allow
# https://challenges.cloudflare.com in script-src, frame-src, and connect-src.
